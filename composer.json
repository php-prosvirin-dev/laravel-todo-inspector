{
  "name": "php-prosvirin-dev/laravel-todo-inspector",
  "description": "Scan and manage TODO, FIXME, HACK comments in Laravel projects",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "todo",
    "inspector",
    "scanner",
    "fixme",
    "technical-debt",
    "code-quality"
  ],
  "authors": [
    {
      "name": "Yauheni Prasviryn",
      "email": "php.prosvirin.dev@gmail.com"
    }
  ],
  "homepage": "https://github.com/php-prosvirin-dev/laravel-todo-inspector",
  "support": {
    "issues": "https://github.com/php-prosvirin-dev/laravel-todo-inspector/issues",
    "source": "https://github.com/php-prosvirin-dev/laravel-todo-inspector"
  },
  "require": {
    "php": "^8.1",
    "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
    "illuminate/console": "^9.0|^10.0|^11.0|^12.0|^13.0",
    "illuminate/database": "^9.0|^10.0|^11.0|^12.0|^13.0",
    "illuminate/filesystem": "^9.0|^10.0|^11.0|^12.0|^13.0",
    "illuminate/routing": "^9.0|^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0|^3.0",
    "laravel/pint": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Prosvirin\\LaravelTodoInspector\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Prosvirin\\LaravelTodoInspector\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Prosvirin\\LaravelTodoInspector\\TodoInspectorServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "test": "pest",
    "test:coverage": "pest --coverage",
    "test:unit": "pest tests/Unit",
    "test:feature": "pest tests/Feature"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "composer/installers": true
    },
    "sort-packages": true
  }
}